{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AEGIS English",
  "version": "0.1.8",
  "identifier": "com.aegis.english.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1421",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IENGRjg4QUNBQjcyNUU1OEEKUldTSzVTVzN5b3I0ejBIemd6TjhNQlpaQVZFZE42TElUNnRFUm5GeEJZWVFPVnVNTU5UdThGbVAK",
      "endpoints": [
        "https://github.com/dota-pilot1/aegis-english/releases/latest/download/latest.json"
      ]
    }
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AEGIS English",
        "width": 1440,
        "height": 900,
        "minWidth": 1100,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
